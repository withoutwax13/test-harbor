{
  "name": "test-harbor",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @testharbor/api",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:migrate": "node scripts/db-migrate-container.mjs",
    "smoke:ingest": "node scripts/smoke-ingest.mjs",
    "db:migrate:container": "node scripts/db-migrate-container.mjs",
    "seed:local": "node scripts/seed-local.mjs",
    "smoke:all": "node scripts/smoke-all.mjs",
    "test:ingest:contract": "node scripts/test-ingest-contract.mjs",
    "smoke:bootstrap": "bash scripts/smoke-all.sh",
    "smoke:webhooks": "node scripts/smoke-webhooks.mjs",
    "smoke:webhooks:dead": "node scripts/smoke-webhooks-dead.mjs",
    "smoke:webhooks:auth:negative": "node scripts/smoke-webhooks-negative-auth.mjs",
    "smoke:webhooks:auth": "node scripts/smoke-webhooks-auth.mjs",
    "smoke:webhooks:dead:auth": "node scripts/smoke-webhooks-dead-auth.mjs",
    "smoke:webhooks:suite": "node scripts/smoke-webhooks-suite.mjs",
    "smoke:webhooks:clear-secret": "node scripts/smoke-webhooks-clear-secret.mjs",
    "smoke:webhooks:disable-after-queue": "node scripts/smoke-webhooks-disable-after-queue.mjs",
    "smoke:webhooks:route-contract": "node scripts/smoke-webhooks-route-contract.mjs",
    "smoke:auth-explorer": "node scripts/smoke-auth-explorer.mjs",
    "smoke:notifications-retention": "node scripts/smoke-notifications-retention.mjs",
    "smoke:auth:explorer": "node scripts/smoke-auth-explorer.mjs",
    "smoke:notifications:retention": "node scripts/smoke-notifications-retention.mjs"
  }
}
